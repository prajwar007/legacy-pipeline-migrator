# Copy to .env and adjust as needed. docker-compose.yml reads these
# automatically; the app itself (dags/transaction_pipeline_dag.py,
# oracle_client.connect, sftp_client) reads the ORACLE_*/SFTP_* ones
# directly from the environment at runtime.

# Oracle - SYS password is only used to initialize the container;
# the app itself connects as ORACLE_USER, never as SYS.
ORACLE_SYS_PASSWORD=dev_sys_password
ORACLE_USER=migrator
ORACLE_PASSWORD=dev_password
# ORACLE_PDB=FREEPDB1
# ORACLE_PDB names the pluggable database used in the connection string.
# gvenzl/oracle-free ships with a default PDB already named FREEPDB1 built
# into the image - this is used for building the DSN below, NOT to create
# a new PDB (docker-compose.yml deliberately does not set ORACLE_DATABASE,
# since setting it to this same default name causes an ORA-65012 collision
# with the one that already exists in the image).

# When connecting from the host (e.g. running pytest locally against the
# containers), use: ORACLE_DSN=localhost:1521/FREEPDB1
# When connecting from inside the `app` container on the same compose
# network, docker-compose.yml already sets this to oracle:1521/FREEPDB1.
ORACLE_DSN=localhost:1521/FREEPDB1

# SFTP
SFTP_USERNAME=migrator
SFTP_PASSWORD=pass
SFTP_HOST=localhost
SFTP_PORT=2222
SFTP_REMOTE_DIR=/incoming

# Alerting (optional - see src/pipeline/alerting.py and RUNBOOK.md).
# Leave unset locally; send_alert() no-ops safely without it.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
